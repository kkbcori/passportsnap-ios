<?xml version="1.0" encoding="UTF-8"?>
<!--
  LaunchScreen.storyboard — PassportSnap dark theme
  Background: #0C0F1A (matches app bg)
  Shows logo icon + app name centred, no "Powered by React Native" label.

  NOTE: The launch screen is cached by iOS and may not update immediately on
  device. If you see the old white screen after replacing this file:
    1. Delete the app from the device
    2. Clean Build Folder in Xcode (⇧⌘K)
    3. Reinstall
-->
<document
  type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB"
  version="3.0"
  toolsVersion="21701"
  targetRuntime="iOS.CocoaTouch"
  propertyAccessControl="none"
  useAutolayout="YES"
  launchScreen="YES"
  useTraitCollections="YES"
  useSafeAreas="YES"
  colorMatched="YES"
  initialViewController="01J-lp-oVM">

  <device id="retina6_12" orientation="portrait" appearance="dark"/>

  <dependencies>
    <deployment identifier="iOS"/>
    <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="21705"/>
    <capability name="Safe area layout guides" minToolsVersion="9.0"/>
    <capability name="System colors in document resources" minToolsVersion="11.0"/>
    <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
  </dependencies>

  <scenes>
    <!--View Controller-->
    <scene sceneID="EHf-IW-A2E">
      <objects>
        <viewController id="01J-lp-oVM" sceneMemberID="viewController">
          <view key="view" contentMode="scaleToFill" id="Ze5-6b-2t3">
            <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>

            <subviews>
              <!-- App Icon image — uses the AppIcon asset we already have -->
              <imageView
                clipsSubviews="YES"
                userInteractionEnabled="NO"
                contentMode="scaleAspectFit"
                image="AppIconLaunch"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="PS-ic-001">
                <rect key="frame" x="146.5" y="346" width="100" height="100"/>
              </imageView>

              <!-- "PassportSnap" wordmark -->
              <label
                opaque="NO"
                userInteractionEnabled="NO"
                contentMode="left"
                text="PassportSnap"
                textAlignment="center"
                lineBreakMode="middleTruncation"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="PS-lbl-001">
                <rect key="frame" x="0" y="464" width="393" height="36"/>
                <fontDescription key="fontDescription" type="boldSystem" pointSize="28"/>
                <color key="textColor" red="0.941" green="0.949" blue="1.0" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                <nil key="highlightedColor"/>
              </label>

              <!-- Subtle tagline -->
              <label
                opaque="NO"
                userInteractionEnabled="NO"
                contentMode="left"
                text="Passport Photos in Seconds"
                textAlignment="center"
                lineBreakMode="middleTruncation"
                translatesAutoresizingMaskIntoConstraints="NO"
                id="PS-lbl-002">
                <rect key="frame" x="0" y="506" width="393" height="20"/>
                <fontDescription key="fontDescription" type="system" pointSize="14"/>
                <color key="textColor" red="0.42" green="0.45" blue="0.58" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                <nil key="highlightedColor"/>
              </label>
            </subviews>

            <!-- Background colour: #0C0F1A -->
            <color key="backgroundColor"
                   red="0.047" green="0.059" blue="0.102"
                   alpha="1" colorSpace="custom" customColorSpace="sRGB"/>

            <constraints>
              <!-- Icon: centred horizontally, centred vertically slightly above middle -->
              <constraint firstItem="PS-ic-001" firstAttribute="centerX"
                          secondItem="Ze5-6b-2t3" secondAttribute="centerX"
                          id="c-ic-cx"/>
              <constraint firstItem="PS-ic-001" firstAttribute="centerY"
                          secondItem="Ze5-6b-2t3" secondAttribute="centerY"
                          constant="-60"
                          id="c-ic-cy"/>
              <constraint firstItem="PS-ic-001" firstAttribute="width"
                          constant="100" id="c-ic-w"/>
              <constraint firstItem="PS-ic-001" firstAttribute="height"
                          constant="100" id="c-ic-h"/>

              <!-- Wordmark: centred horizontally, 28pt below icon -->
              <constraint firstItem="PS-lbl-001" firstAttribute="top"
                          secondItem="PS-ic-001" secondAttribute="bottom"
                          constant="28" id="c-lbl1-top"/>
              <constraint firstItem="PS-lbl-001" firstAttribute="leading"
                          secondItem="Bcu-3y-fUS" secondAttribute="leading"
                          id="c-lbl1-lead"/>
              <constraint firstItem="PS-lbl-001" firstAttribute="trailing"
                          secondItem="Bcu-3y-fUS" secondAttribute="trailing"
                          id="c-lbl1-trail"/>

              <!-- Tagline: 8pt below wordmark -->
              <constraint firstItem="PS-lbl-002" firstAttribute="top"
                          secondItem="PS-lbl-001" secondAttribute="bottom"
                          constant="8" id="c-lbl2-top"/>
              <constraint firstItem="PS-lbl-002" firstAttribute="leading"
                          secondItem="Bcu-3y-fUS" secondAttribute="leading"
                          id="c-lbl2-lead"/>
              <constraint firstItem="PS-lbl-002" firstAttribute="trailing"
                          secondItem="Bcu-3y-fUS" secondAttribute="trailing"
                          id="c-lbl2-trail"/>
            </constraints>

            <viewLayoutGuide key="safeArea" id="Bcu-3y-fUS"/>
          </view>
        </viewController>

        <placeholder placeholderIdentifier="IBFirstResponder"
                     id="iYj-Kq-Ea1"
                     userLabel="First Responder"
                     sceneMemberID="firstResponder"/>
      </objects>
      <point key="canvasLocation" x="52" y="375"/>
    </scene>
  </scenes>

  <!--
    AppIconLaunch — references the app icon PNG for the splash screen.

    IMPORTANT: This requires a named image resource in the asset catalog.
    Add a new "Image Set" called "AppIconLaunch" in Images.xcassets and
    drag your 1024px icon PNG into the @1x slot of the Universal idiom.

    Quick alternative: delete the <imageView> above and use a plain coloured
    circle View instead — the storyboard will still display the wordmark and
    tagline correctly without any image asset setup.
  -->
  <resources>
    <image name="AppIconLaunch" width="1024" height="1024"/>
  </resources>

</document>
