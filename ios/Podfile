# PassportSnap iOS Podfile
# React Native 0.73.6 — Production build (Flipper removed)
#
# After any change to this file:
#   cd ios && pod install --repo-update
#   Then open PassportSnap.xcworkspace (NOT .xcodeproj)

require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# min_ios_version_supported is set by React Native (currently iOS 13.4)
platform :ios, '13.4'
prepare_react_native_project!

target 'PassportSnap' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # Flipper is disabled — it is not needed for production and causes
    # build failures on Apple Silicon Macs with recent Xcode versions.
    :flipper_configuration => FlipperConfiguration.disabled,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'PassportSnapTests' do
    inherit! :complete
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # Fix: Some pods set IPHONEOS_DEPLOYMENT_TARGET below the project minimum.
    # This silences the resulting warnings (and occasional build errors).
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        current = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
        if current && current.to_f < 13.4
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.4'
        end
      end
    end
  end
end
