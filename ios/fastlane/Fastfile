# ios/fastlane/Fastfile
#
# PassportSnap iOS — Fastlane configuration
#
# Lanes:
#   build   → compile + archive → produces PassportSnap.ipa
#   deploy  → build + upload to TestFlight
#
# Called from GitHub Actions:
#   bundle exec fastlane build
#   bundle exec fastlane deploy

default_platform :ios

# ── App Store Connect API key ───────────────────────────────────────────────
# Reads from environment variables set by GitHub Actions secrets.
# This avoids interactive Apple ID 2FA prompts during CI.
def api_key
  app_store_connect_api_key(
    key_id:        ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id:     ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content:   Base64.strict_decode64(ENV["APP_STORE_CONNECT_KEY_BASE64"]),
    is_key_content_base64: false,
    in_house:      false
  )
end

platform :ios do

  # ── before_all ─────────────────────────────────────────────────────────────
  before_all do
    clear_derived_data(derived_data_path: "build/DerivedData")
  end

  # ── Lane: build ────────────────────────────────────────────────────────────
  desc "Build and sign PassportSnap for App Store distribution"
  lane :build do

    build_app(
      workspace:             "PassportSnap.xcworkspace",
      scheme:                "PassportSnap",
      configuration:         "Release",
      output_directory:      "build",
      output_name:           "PassportSnap.ipa",
      derived_data_path:     "build/DerivedData",
      export_method:         "app-store",
      xcargs:                "DEVELOPMENT_TEAM=THN78NT3R9 CODE_SIGN_STYLE=Manual",
      export_options: {
        teamID:              "THN78NT3R9",
        provisioningProfiles: {
          "com.passportsnap" => "PassportSnap App Store"
        },
        signingStyle:        "manual",
        stripSwiftSymbols:   true,
        uploadBitcode:       false,
        uploadSymbols:       true,
        compileBitcode:      false
      },
      buildlog_path:         "build/logs",
      suppress_xcode_output: false
    )

    UI.success "✅ Build complete → ios/build/PassportSnap.ipa"
  end

  # ── Lane: deploy ───────────────────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :deploy do
    build

    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "build/PassportSnap.ipa",
      skip_waiting_for_build_processing: true,
      notify_external_testers:           false,
      changelog:                         "Build #{ENV['GITHUB_RUN_NUMBER']} — automated CI build"
    )

    UI.success "✅ Uploaded to TestFlight — build #{ENV['GITHUB_RUN_NUMBER']}"
  end

  # ── Error handler ──────────────────────────────────────────────────────────
  error do |lane, exception|
    UI.error "Lane #{lane} failed: #{exception.message}"
  end

end
